---
# Cribl Stream inputs configuration
# Generated by Ansible - cribl_docker_stack role
# IPFIX/NetFlow handled by Stream (not Edge)

inputs:
  # IPFIX (NetFlow v10) UDP listener on port {{ cribl_docker_stack_netflow_port }}
  # UniFi Dream Wall sends IPFIX to this port
  # Using netflow source type which supports v5, v9, and IPFIX (v10)
  in_ipfix:
    id: in_ipfix
    type: netflow
    disabled: false
    sendToRoutes: false
    host: "0.0.0.0"
    port: {{ cribl_docker_stack_netflow_port }}
    pqEnabled: true
    connections:
      - output: splunk_hec
        pipeline: ipfix
