---
# Cribl Edge inputs configuration
# Generated by Ansible - cribl_docker_stack role

inputs:
{% for port in cribl_docker_stack_syslog_ports %}
  # Syslog listener on port {{ port }} (TCP + UDP)
  in_syslog_{{ port }}:
    id: in_syslog_{{ port }}
    type: syslog
    disabled: false
    pipeline: syslog
    sendToRoutes: false
    host: "0.0.0.0"
    tcpPort: {{ port }}
    udpPort: {{ port }}
    tls:
      disabled: true
    maxActiveCxn: 100
    enableProxyHeader: false
    captureHeaders: false
    activityLogSampleRate: 100
    enableMultiline: false
    pqEnabled: true
    connections:
      - output: splunk_hec
        pipeline: syslog

{% endfor %}
  # NetFlow UDP listener on port {{ cribl_docker_stack_netflow_port }}
  in_netflow:
    id: in_netflow
    type: netflow
    disabled: false
    pipeline: syslog
    sendToRoutes: false
    host: "0.0.0.0"
    port: {{ cribl_docker_stack_netflow_port }}
    pqEnabled: true
    connections:
      - output: splunk_hec
        pipeline: syslog
